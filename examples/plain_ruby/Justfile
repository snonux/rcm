# Apply configuration
run:
    ruby config.rb

# Dry run — show what would change without making changes
dry:
    ruby config.rb --dry

# Verbose output
debug:
    ruby config.rb --debug

# Apply the agent-backed example
agents:
    ruby agents.rb

# Dry run the agent-backed example
agents-dry:
    ruby agents.rb --dry

# Verbose output for the agent-backed example
agents-debug:
    ruby agents.rb --debug
